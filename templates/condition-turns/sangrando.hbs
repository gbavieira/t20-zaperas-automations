<div class="t20-sustain-prompt {{promptClass}}">
  <div class="t20-sustain-title">
    <i class="fas fa-droplet"></i>
    Sangrando: {{actorName}}
  </div>
  <div class="t20-sustain-body">
    <b>{{actorName}}</b> está sangrando.
    <br>
    Rolar teste de <b>Constituição (CD 15)</b> para estancar?
  </div>
  <div class="t20-sustain-actions">
    <button class="sustain-yes"
        data-action="rolar-constituicao"
        data-actor-id="{{actorId}}"
        data-token-id="{{tokenId}}"
        data-effect-id="{{effectId}}">
      <i class="fas fa-dice-d20"></i> Rolar Constituição
    </button>
  </div>
</div>
