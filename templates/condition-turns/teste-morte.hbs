<div class="t20-sustain-prompt t20-sangrando-prompt">
  <div class="t20-sustain-title">
    <i class="fas fa-skull"></i>
    Teste de Morte: {{actorName}}
  </div>
  <div class="t20-sustain-body">
    <b>{{actorName}}</b> está sangrando com 0 PV ou menos.
    <br>
    Execute o <b>Teste de Morte</b> (macro "Sangrando" do sistema).
  </div>
  <div class="t20-sustain-actions">
    <button class="sustain-yes"
        data-action="executar-teste-morte"
        data-actor-id="{{actorId}}"
        data-token-id="{{tokenId}}">
      <i class="fas fa-skull"></i> Executar Teste de Morte
    </button>
  </div>
</div>
