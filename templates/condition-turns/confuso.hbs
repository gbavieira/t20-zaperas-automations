<div class="t20-sustain-prompt t20-confuso-result">
  <div class="t20-sustain-title">
    <i class="fas fa-head-side-virus"></i>
    Confuso: {{actorName}}
  </div>
  <div class="t20-sustain-body">
    <b>{{actorName}}</b> está confuso!
    <br>
    <span class="confuso-result" style="font-weight: bold; color: #c41e3a;">
      {{effectText}}
    </span>
    {{#if (eq result 6)}}
    <br>
    <i style="color: #28a745;">(A confusão passou — age normalmente)</i>
    {{/if}}
  </div>
</div>
