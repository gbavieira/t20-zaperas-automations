<div class="t20-sustain-prompt t20-confuso-prompt">
  <div class="t20-sustain-title">
    <i class="fas fa-head-side-virus"></i>
    Confuso: {{actorName}}
  </div>
  <div class="t20-sustain-body">
    <b>{{actorName}}</b> está confuso!
    <br>
    Rolar <b>1d6</b> para determinar o efeito da confusão?
  </div>
  <div class="t20-sustain-actions">
    <button class="sustain-yes"
        data-action="rolar-confusao"
        data-actor-id="{{actorId}}"
        data-token-id="{{tokenId}}"
        data-effect-id="{{effectId}}">
      <i class="fas fa-dice-d6"></i> Rolar 1d6 (Confusão)
    </button>
  </div>
</div>
