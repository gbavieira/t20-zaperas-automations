<div class="t20-zaperas-config-list" style="padding:8px;">
  {{#if actors.length}}
  <table style="width:100%;border-collapse:collapse;font-size:0.92em;">
    <thead>
      <tr style="border-bottom:2px solid #ccc;font-weight:bold;text-align:left;">
        <th style="padding:4px 6px;">Nome</th>
        <th style="padding:4px 6px;width:10em;">Tipo</th>
        <th style="padding:4px 6px;width:5em;text-align:center;">Ações</th>
      </tr>
    </thead>
    <tbody>
      {{#each actors}}
      <tr data-idx="{{@index}}" style="border-bottom:1px solid #eee;">
        <td style="padding:4px 6px;"><strong>{{this.name}}</strong></td>
        <td style="padding:4px 6px;">{{#if (eq this.type 'character')}}Personagem{{else}}{{this.type}}{{/if}}</td>
        <td style="padding:4px 2px;text-align:center;">
          <button type="button" data-action="removeActor"
            title="Remover" style="padding:2px 7px;margin:1px;cursor:pointer;color:#b52d34;">
            <i class="fas fa-trash"></i>
          </button>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <p style="color:#888;text-align:center;margin:16px 0;">
    Nenhum ator configurado. O cálculo usará todos os personagens.
  </p>
  {{/if}}

  <div style="display:flex;justify-content:space-between;align-items:center;margin-top:14px;gap:8px;">
    <div style="display:flex;gap:6px;">
      <button type="button" data-action="addActor" style="cursor:pointer;">
        <i class="fas fa-plus"></i> Adicionar Ator
      </button>
      <button type="button" data-action="resetDefaults"
        style="cursor:pointer;color:#888;font-size:0.88em;">
        <i class="fas fa-rotate-left"></i> Restaurar Padrão
      </button>
    </div>
    <button type="button" data-action="save"
      style="cursor:pointer;color:#006c00;font-weight:bold;padding:4px 14px;">
      <i class="fas fa-save"></i> Salvar
    </button>
  </div>
</div>
